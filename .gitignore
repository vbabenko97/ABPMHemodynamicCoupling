# OS and editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Python bytecode and build metadata
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Python tooling
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
